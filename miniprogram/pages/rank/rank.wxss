.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFD6BA 0%, #FFE5D9 40%, #FFEFD5 100%);
  padding-bottom: 140rpx;
}

.header {
  padding: 80rpx 40rpx 50rpx;
  text-align: center;
}

.header-decoration {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #8B5A3C;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #B07A5C;
  letter-spacing: 2rpx;
}

.list-container {
  background: #FFFAF5;
  border-radius: 36rpx 36rpx 0 0;
  padding: 40rpx 32rpx;
  box-shadow: 0 -8rpx 30rpx rgba(255, 184, 140, 0.15);
}

.top-three {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 50rpx 0;
  gap: 20rpx;
}

.first-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 2;
}

.second-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 1;
}

.third-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 3;
}

.medal {
  font-size: 52rpx;
  margin-bottom: 14rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(255, 184, 140, 0.3));
}

.first-place .card {
  width: 280rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFB347 100%);
  border-radius: 24rpx;
  text-align: center;
  transform: scale(1.1);
  box-shadow: 0 10rpx 30rpx rgba(255, 179, 71, 0.4);
}

.second-place .card,
.third-place .card {
  width: 240rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #FFB997 0%, #F8AD7B 100%);
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(255, 154, 139, 0.3);
}

.third-place .card {
  background: linear-gradient(135deg, #FFCBA4 0%, #E8AC7E 100%);
  box-shadow: 0 6rpx 20rpx rgba(232, 172, 126, 0.3);
}

.card .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 auto 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.card .name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.card .likes {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 14rpx;
  font-weight: bold;
}

.card .content {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.other-ranks {
  margin-top: 40rpx;
}

.list-header {
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B5A3C;
  letter-spacing: 1rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B89E8E;
  letter-spacing: 2rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFCF7;
  border-radius: 20rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid #FFF0E0;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.08);
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB997 0%, #F8AD7B 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(255, 154, 139, 0.3);
}

.rank-info {
  flex: 1;
  overflow: hidden;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.small-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB997 0%, #F8AD7B 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #8B5A3C;
}

.rank-content {
  font-size: 26rpx;
  color: #6B5544;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.rank-likes {
  font-size: 28rpx;
  color: #F8AD7B;
  font-weight: bold;
  margin-left: 20rpx;
}
