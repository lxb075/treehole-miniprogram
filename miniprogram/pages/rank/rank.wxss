.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding-bottom: 120rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.list-container {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.top-three {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 40rpx 0;
  gap: 20rpx;
}

.first-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 2;
}

.second-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 1;
}

.third-place {
  display: flex;
  flex-direction: column;
  align-items: center;
  order: 3;
}

.medal {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.first-place .card {
  width: 280rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  border-radius: 20rpx;
  text-align: center;
  transform: scale(1.1);
}

.second-place .card,
.third-place .card {
  width: 240rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #c0c0c0 0%, #a0a0a0 100%);
  border-radius: 16rpx;
  text-align: center;
}

.card .avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin: 0 auto 12rpx;
}

.card .name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.card .likes {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 12rpx;
}

.card .content {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.other-ranks {
  margin-top: 32rpx;
}

.list-header {
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.rank-info {
  flex: 1;
  overflow: hidden;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.small-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.user-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.rank-content {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.rank-likes {
  font-size: 28rpx;
  color: #f5576c;
  font-weight: bold;
  margin-left: 20rpx;
}
