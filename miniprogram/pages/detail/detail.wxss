/* pages/detail/detail.wxss - 树洞详情样式 */

/* ============== 容器与背景 ============== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE5D9 0%, #FFD6BA 40%, #FFEFD5 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* ============== 加载状态 ============== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #B89580;
  letter-spacing: 2rpx;
}

/* ============== 空状态 ============== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.7;
}

.empty-text {
  font-size: 30rpx;
  color: #A88B7A;
  margin-bottom: 40rpx;
  letter-spacing: 1rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF8C61 0%, #FFB997 100%);
  color: #FFFFFF;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 140, 97, 0.3);
}

.empty-btn.secondary {
  background: rgba(255, 255, 255, 0.7);
  color: #A88B7A;
  box-shadow: 0 4rpx 10rpx rgba(168, 139, 122, 0.15);
}

/* ============== 详情卡片 ============== */
.detail-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 140, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============== 头部 ============== */
.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.detail-header .avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.25);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-emoji {
  font-size: 52rpx;
  line-height: 1;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.anonymous-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #6B4F3F;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.create-time {
  font-size: 24rpx;
  color: #B89580;
}

/* ============== 分割线 ============== */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 140, 97, 0.3) 50%, transparent 100%);
  margin: 8rpx 0 32rpx;
}

/* ============== 正文 ============== */
.detail-content {
  font-size: 32rpx;
  line-height: 1.9;
  color: #4A3728;
  letter-spacing: 1.5rpx;
  word-break: break-all;
  white-space: pre-wrap;
  margin-bottom: 32rpx;
}

/* ============== 图片 ============== */
.detail-image-wrap {
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  background: rgba(255, 230, 215, 0.5);
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.2);
}

.detail-image {
  width: 100%;
  display: block;
}

.image-tip {
  text-align: center;
  font-size: 22rpx;
  color: #B89580;
  padding: 12rpx 0;
  background: rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}

/* ============== 底部互动 ============== */
.detail-footer {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0 8rpx;
  border-top: 2rpx dashed rgba(255, 140, 97, 0.2);
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 32rpx;
  border-radius: 50rpx;
  background: rgba(255, 230, 215, 0.5);
  transition: all 0.2s ease;
}

.action-btn-hover {
  transform: scale(0.96);
  background: rgba(255, 200, 170, 0.6);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.action-text {
  font-size: 26rpx;
  color: #A88B7A;
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.action-count {
  font-size: 26rpx;
  color: #A88B7A;
  font-weight: 600;
}

.like-btn.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF8C9B 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 155, 0.35);
}

.like-btn.active .action-text,
.like-btn.active .action-count {
  color: #FFFFFF;
}

.fav-btn.active {
  background: linear-gradient(135deg, #FFE4A8 0%, #FFCB6B 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 203, 107, 0.35);
}

.fav-btn.active .action-text {
  color: #8B5A1A;
}

/* ============== 底部小语 ============== */
.footer-quote {
  text-align: center;
  margin-top: 60rpx;
  font-size: 24rpx;
  color: #B89580;
  letter-spacing: 2rpx;
  opacity: 0.85;
}

/* ============== 浮动按钮:返回我的 ============== */
.fab-back-my {
  position: fixed;
  right: 32rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB997 0%, #FF8C61 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 97, 0.35);
  z-index: 999;
}

.fab-back-my-hover {
  transform: scale(0.92);
  box-shadow: 0 4rpx 10rpx rgba(255, 140, 97, 0.25);
}

.fab-back-my .fab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.fab-back-my .fab-text {
  font-size: 20rpx;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
