/* ============== 容器与背景 ============== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE5D9 0%, #FFD6BA 40%, #FFEFD5 100%);
  padding-bottom: 60rpx;
}

/* ============== Header ============== */
.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.header-decoration {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 50rpx;
  font-weight: bold;
  color: #8B5A3C;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #B07A5C;
  letter-spacing: 2rpx;
  display: block;
}

/* ============== 用户卡 ============== */
.user-card {
  margin: 0 32rpx 28rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-info .avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 140, 0.25);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-emoji {
  font-size: 50rpx;
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.user-card .anonymous-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B5A3C;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-tag {
  font-size: 22rpx;
  color: #B07A5C;
  background: rgba(255, 184, 140, 0.15);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  align-self: flex-start;
}

.login-btn,
.refresh-btn {
  background: linear-gradient(135deg, #FFB997 0%, #FF8C61 100%);
  color: #fff;
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 97, 0.3);
  flex-shrink: 0;
}

.login-btn text,
.refresh-btn text {
  color: #fff;
  font-size: 26rpx;
}

/* ============== 主表单容器 ============== */
.publish-container {
  background: #FFFAF5;
  border-radius: 36rpx 36rpx 0 0;
  padding: 40rpx 32rpx;
  min-height: 70vh;
  box-shadow: 0 -8rpx 30rpx rgba(255, 184, 140, 0.15);
}

/* ============== 输入区 ============== */
.input-area {
  background: #FFFCF7;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #FFF0E0;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 140, 0.08);
}

.content-input {
  width: 100%;
  min-height: 280rpx;
  font-size: 32rpx;
  line-height: 1.7;
  color: #5C4033;
  letter-spacing: 1rpx;
}

.input-placeholder {
  color: #D4B8A4;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.word-count {
  text-align: right;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #F5E1D0;
}

.word-count text {
  font-size: 24rpx;
  color: #C9A98E;
}

/* ============== 图片上传 ============== */
.image-upload-area {
  margin-bottom: 32rpx;
}

.upload-title {
  margin-bottom: 16rpx;
}

.upload-title text {
  font-size: 28rpx;
  color: #8B5A3C;
  font-weight: 500;
}

.image-preview {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.2);
}

.preview-img {
  width: 100%;
  height: 100%;
  display: block;
}

.image-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mask-text {
  color: #fff;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: #FF6B6B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid #FFFAF5;
}

.remove-btn text {
  color: #fff;
  font-size: 32rpx;
  line-height: 1;
}

.upload-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 20rpx;
  background: #FFF6EC;
  border: 2rpx dashed #FFB997;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.upload-btn:active {
  background: #FFE8D4;
  transform: scale(0.98);
}

.upload-icon {
  font-size: 64rpx;
  color: #FF8C61;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #B07A5C;
}

/* ============== 温馨提示 ============== */
.warm-tip {
  background: linear-gradient(135deg, #FFE9DC 0%, #FFD9C0 100%);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.warm-tip text {
  font-size: 26rpx;
  color: #8B5A3C;
  letter-spacing: 2rpx;
}

/* ============== 发布按钮 ============== */
.publish-btn {
  background: linear-gradient(135deg, #FFB997 0%, #FF8C61 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  letter-spacing: 6rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 97, 0.35);
  transition: all 0.2s;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 97, 0.3);
}

.publish-btn.disabled {
  background: #E0D2C5;
  color: #A89888;
  box-shadow: none;
}

.publish-btn.disabled:active {
  transform: none;
}

.publish-btn text {
  color: inherit;
  font-size: 32rpx;
  letter-spacing: 6rpx;
}

/* ============== 浮动按钮:返回我的 ============== */
.fab-back-my {
  position: fixed;
  right: 32rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB997 0%, #FF8C61 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 97, 0.35);
  z-index: 999;
}

.fab-back-my-hover {
  transform: scale(0.92);
  box-shadow: 0 4rpx 10rpx rgba(255, 140, 97, 0.25);
}

.fab-back-my .fab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.fab-back-my .fab-text {
  font-size: 20rpx;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
