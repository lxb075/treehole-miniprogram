.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.publish-container {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  min-height: calc(100vh - 200rpx);
}

.input-area {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.content-input {
  width: 100%;
  height: 300rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
}

.word-count {
  text-align: right;
  margin-top: 16rpx;
}

.word-count text {
  font-size: 24rpx;
  color: #999;
}

.anonymous-info {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.anonymous-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.refresh-btn {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.refresh-btn text {
  font-size: 28rpx;
  color: #fff;
}

.warning {
  text-align: center;
  padding: 24rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.warning text {
  font-size: 26rpx;
  color: #e6a23c;
}

.publish-btn {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  text-align: center;
}

.publish-btn text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.publish-btn.disabled {
  opacity: 0.5;
}