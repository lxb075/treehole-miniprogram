<view class="container">
  <view class="header">
    <text class="title">发布留言</text>
    <text class="subtitle">匿名发布，畅所欲言</text>
  </view>

  <view class="publish-container">
    <view class="input-area">
      <textarea
        class="content-input"
        placeholder="写下你想说的话..."
        maxlength="500"
        bindinput="handleInput"
        value="{{content}}"
      />
      <view class="word-count">
        <text>{{content.length}}/500</text>
      </view>
    </view>

    <view class="expire-section">
      <view class="info-row" bindtap="toggleExpirePicker">
        <text class="info-label">留言有效期</text>
        <view class="expire-select">
          <text>{{expireHours >= 168 ? (expireHours / 24) + '天' : expireHours + '小时'}}</text>
          <text class="arrow">▼</text>
        </view>
      </view>
      <view class="expire-options" wx:if="{{showExpirePicker}}">
        <view
          wx:for="{{expireOptions}}"
          wx:key="value"
          class="expire-option {{expireHours === item.value ? 'active' : ''}}"
          bindtap="selectExpire"
          data-hours="{{item.value}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="anonymous-info">
      <view class="info-row">
        <text class="info-label">你的匿名代号</text>
        <text class="anonymous-name">{{anonymousName}}</text>
      </view>
      <view class="refresh-btn" bindtap="refreshName">
        <text>🔄 换一个</text>
      </view>
    </view>

    <view class="warning">
      <text>⚠️ 请文明发言，遵守法律法规</text>
    </view>

    <view
      class="publish-btn"
      bindtap="handlePublish"
    >
      <text>发布留言</text>
    </view>
  </view>
</view>
