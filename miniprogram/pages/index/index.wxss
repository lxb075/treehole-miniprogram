/* ============== 容器与背景 ============== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE5D9 0%, #FFD6BA 40%, #FFEFD5 100%);
  padding-bottom: 140rpx;
}

/* ============== 顶部 Header ============== */
.header {
  padding: 60rpx 32rpx 36rpx;
}

.user-bar {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 140, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.user-bar .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD1DC 0%, #FFB6C1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 140, 0.25);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B5A3C;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-tip {
  font-size: 22rpx;
  color: #B07A5C;
}

.user-arrow {
  font-size: 40rpx;
  color: #B07A5C;
  margin-left: 8rpx;
  font-weight: 300;
}

.title-wrap {
  text-align: center;
}

.header-decoration {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #8B5A3C;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #B07A5C;
  letter-spacing: 2rpx;
  display: block;
}

/* ============== 列表容器 ============== */
.list-container {
  background: #FFFAF5;
  border-radius: 36rpx 36rpx 0 0;
  padding: 36rpx 32rpx;
  box-shadow: 0 -8rpx 30rpx rgba(255, 184, 140, 0.15);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.list-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #8B5A3C;
}

.list-count {
  font-size: 24rpx;
  color: #C9A98E;
}

/* ============== 空状态 ============== */
.empty-state {
  text-align: center;
  padding: 120rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 28rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.empty-text {
  font-size: 28rpx;
  color: #B89E8E;
  letter-spacing: 2rpx;
  margin-bottom: 36rpx;
  display: block;
}

.empty-btn {
  background: linear-gradient(135deg, #FFB997 0%, #FF8C61 100%);
  color: #fff;
  padding: 18rpx 48rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 140, 97, 0.3);
}

.empty-btn text {
  color: #fff;
  font-size: 28rpx;
}

/* ============== 留言卡片 ============== */
.message-scroll {
  max-height: calc(100vh - 480rpx);
}

.message-card {
  background: #FFFCF7;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 140, 0.1);
  border: 2rpx solid #FFF0E0;
  transition: transform 0.2s;
}

.message-card-hover {
  transform: scale(0.98);
  background: #FFF8EE;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.message-header .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 184, 140, 0.2);
  flex-shrink: 0;
  overflow: hidden;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.anonymous-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B5A3C;
  margin-bottom: 4rpx;
}

.create-time {
  font-size: 22rpx;
  color: #B89E8E;
}

.message-content {
  font-size: 30rpx;
  color: #5C4033;
  line-height: 1.7;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  word-break: break-all;
}

.message-content text {
  display: block;
}

/* ============== 图片缩略图 ============== */
.message-image-wrap {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.message-image {
  width: 100%;
  max-height: 360rpx;
  border-radius: 16rpx;
  display: block;
  background: #f0e6dc;
}

/* ============== 操作按钮 ============== */
.message-footer {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #FFF0E0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  background: #FFF6EC;
  transition: all 0.2s;
}

.action-btn-hover {
  background: #FFE8D4;
  transform: scale(0.96);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.action-count,
.action-text {
  font-size: 26rpx;
  color: #B07A5C;
}

.like-btn.active .action-count,
.like-btn.active .action-icon {
  color: #FF6B6B;
}

.fav-btn.active .action-text,
.fav-btn.active .action-icon {
  color: #FFB347;
}

/* ============== 加载提示 ============== */
.load-tip {
  text-align: center;
  padding: 36rpx 0 12rpx;
  color: #B89E8E;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
