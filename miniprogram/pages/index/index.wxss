.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 120rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.list-container {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.message-scroll {
  max-height: calc(100vh - 400rpx);
}

.message-card {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.message-card.expired {
  opacity: 0.6;
  border: 2rpx dashed #ccc;
}

.message-card.favorited {
  border: 2rpx solid #ffd700;
  background: #fffef5;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.user-info {
  margin-left: 20rpx;
  flex: 1;
}

.anonymous-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.create-time {
  font-size: 22rpx;
  color: #999;
}

.expire-time {
  font-size: 20rpx;
  color: #e6a23c;
  background: #fff8e1;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.message-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.message-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.like-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  border: 1rpx solid #eee;
}

.like-btn.liked {
  border-color: #f5576c;
  background: #fff0f0;
}

.like-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.like-count {
  font-size: 26rpx;
  color: #666;
}

.favorite-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 30rpx;
  border: 1rpx solid #eee;
}

.favorite-btn.favorited {
  border-color: #ffd700;
  background: #fffef0;
}

.favorite-icon {
  font-size: 28rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 30rpx;
  border: 1rpx solid #eee;
}

.share-icon {
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  background: #fff;
}

.load-text {
  font-size: 28rpx;
  color: #667eea;
}
