<view class="container">
  <view class="header">
    <text class="title">校园树洞</text>
    <text class="subtitle">分享你的心声，倾听他人故事</text>
  </view>

  <view class="list-container">
    <view class="list-header">
      <text class="list-title">最新留言</text>
      <text class="list-count">{{messageList.length}} 条</text>
    </view>

    <view wx:if="{{messageList.length === 0}}" class="empty-state">
      <view class="empty-icon">🌳</view>
      <text class="empty-text">还没有留言，快来发布第一条吧！</text>
    </view>

    <scroll-view scroll-y class="message-scroll">
      <view
        wx:for="{{messageList}}"
        wx:key="msgId"
        class="message-card {{item.isExpired ? 'expired' : ''}} {{item.hasFavorited ? 'favorited' : ''}}"
      >
        <view class="message-header">
          <view class="avatar">{{item.anonymousName.charAt(0)}}</view>
          <view class="user-info">
            <text class="anonymous-name">{{item.anonymousName}}</text>
            <view class="time-row">
              <text class="create-time">{{formatTime(item.createTime)}}</text>
              <text class="expire-time" wx:if="{{item.remainingText}}"> {{item.remainingText}}</text>
            </view>
          </view>
        </view>
        <view class="message-content">
          <text>{{item.content}}</text>
        </view>
        <view class="message-footer">
          <view
            class="like-btn {{item.hasLiked ? 'liked' : ''}}"
            bindtap="handleLike"
            data-id="{{item.msgId}}"
            data-liked="{{item.hasLiked}}"
          >
            <text class="like-icon">{{item.hasLiked ? '❤️' : ''}}</text>
            <text class="like-count">{{item.likeCount}}</text>
          </view>
          <view
            class="favorite-btn {{item.hasFavorited ? 'favorited' : ''}}"
            bindtap="handleFavorite"
            data-id="{{item.msgId}}"
            data-favorited="{{item.hasFavorited}}"
          >
            <text class="favorite-icon">{{item.hasFavorited ? '⭐' : '☆'}}</text>
          </view>
          <button class="share-btn" open-type="share" data-index="{{index}}">
            <text class="share-icon">📤</text>
          </button>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <text bindtap="loadMore" class="load-text">加载更多</text>
  </view>
</view>
