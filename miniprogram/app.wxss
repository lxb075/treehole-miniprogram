page {
  background-color: #FFF5EE;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
}

.page-container {
  padding: 0 24rpx;
}

.text-primary {
  color: #FF8C61;
}

.text-secondary {
  color: #8B6F5E;
}

.text-muted {
  color: #B89E8E;
}

.bg-white {
  background-color: #fff;
}

.bg-warm {
  background: linear-gradient(180deg, #FFE5D9 0%, #FFD1B3 100%);
}

.radius-lg {
  border-radius: 24rpx;
}

.radius-md {
  border-radius: 16rpx;
}

.radius-sm {
  border-radius: 8rpx;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.text-center {
  text-align: center;
}
